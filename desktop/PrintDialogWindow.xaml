<Window x:Class="PrintTrackPro.Desktop.PrintDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintTrackPro - Print Intercepted!" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" Topmost="True">
    
    <Grid Margin="30">
        <!-- Centered Dialog Box -->
        <Border Background="#F8FAFC" CornerRadius="12" Padding="30" Width="450">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="25" ShadowDepth="0"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock x:Name="TxtHeader" Text="Print Job Paused" FontSize="26" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtSubHeader" Text="The printer is locked until you submit." FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,5,0,10"/>
                    <TextBlock x:Name="DocumentNameText" Text="Document: Loading..." FontSize="14" Foreground="#64748B" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Gatekeeper Panel (Screen 1) -->
                <StackPanel x:Name="GatekeeperPanel" Grid.Row="1" Visibility="Visible">
                    <TextBlock Text="How do you want to handle this print?" FontSize="16" Foreground="#334155" Margin="0,0,0,20" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    
                    <Button Content="Charge Print Fees" Height="45" Background="#3B82F6" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnCharge_Click" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    
                    <Button Content="No Fees (Print for Free)" Height="45" Background="#E2E8F0" Foreground="#475569" FontSize="16" FontWeight="SemiBold" Click="BtnNoFees_Click" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Print as a Guest" Height="45" Background="#8B5CF6" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnGuestPrint_Click" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Cancel Print (Delete Job)" Height="45" Background="#EF4444" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnCancelPrint_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Student Selection Panel (Screen 2) -->
                <StackPanel x:Name="StudentPanel" Grid.Row="1" Visibility="Collapsed">
                    <TextBlock Text="Select Batch:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboBatches" Height="35" Margin="0,0,0,15" SelectionChanged="ComboBatches_SelectionChanged" DisplayMemberPath="BatchName" SelectedValuePath="Id" />

                    <TextBlock Text="Search Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtStudentSearch" Height="35" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10" TextChanged="TxtStudentSearch_TextChanged" />

                    <TextBlock Text="Select Student:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboStudents" Height="35" Margin="0,0,0,20" DisplayMemberPath="Name" SelectedValuePath="Id" />

                    <Button Content="Proceed &amp; Start Printing" Height="45" Background="#10B981" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnProceed_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="TxtStudentStatus" Foreground="#EF4444" Margin="0,10,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Guest Password Panel -->
                <StackPanel x:Name="GuestPasswordPanel" Grid.Row="1" Visibility="Collapsed">
                    <TextBlock Text="Enter Guest Authorization Password:" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="TxtGuestPassword" Height="35" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,20"/>
                    
                    <Button Content="Verify Password" Height="45" Background="#8B5CF6" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnVerifyGuest_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="TxtGuestPasswordStatus" Foreground="#EF4444" Margin="0,10,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Guest Selection Panel -->
                <StackPanel x:Name="GuestSelectionPanel" Grid.Row="1" Visibility="Collapsed">
                    <TextBlock Text="Select Guest:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboGuests" Height="35" Margin="0,0,0,20" DisplayMemberPath="Name" SelectedValuePath="Id" />

                    <Button Content="Proceed &amp; Start Printing" Height="45" Background="#10B981" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnProceedGuest_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="TxtGuestStatus" Foreground="#EF4444" Margin="0,10,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Billing Form Panel (Screen 3) -->
                <StackPanel x:Name="DetailsPanel" Grid.Row="1" Visibility="Collapsed">
                    <TextBlock Text="Print Type (Auto-Calc):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton x:Name="RadioSingle" Content="Single Sided" GroupName="PrintType" Margin="0,0,10,0" IsChecked="True" Checked="PrintType_Changed"/>
                        <RadioButton x:Name="RadioDouble" Content="Double Sided" GroupName="PrintType" Margin="0,0,10,0" Checked="PrintType_Changed"/>
                        <RadioButton x:Name="RadioBooklet" Content="Booklet" GroupName="PrintType" Checked="PrintType_Changed"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Pages Printed:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtPages" Height="35" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtPages_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Rupees (Cost):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtCost" Height="35" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtCost_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Description:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtDescription" Height="60" TextWrapping="Wrap" Margin="0,0,0,20" Padding="5"/>

                    <TextBlock Text="Payment Status:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="RadioNotPaid" Content="Not Paid" GroupName="Payment" Margin="0,0,15,0" IsChecked="True" Checked="PaymentMethod_Changed"/>
                        <RadioButton x:Name="RadioPaid" Content="Paid (Cash)" GroupName="Payment" Margin="0,0,15,0" Checked="PaymentMethod_Changed"/>
                        <RadioButton x:Name="RadioGpay" Content="Google Pay" GroupName="Payment" Checked="PaymentMethod_Changed"/>
                    </StackPanel>

                    <Image x:Name="ImgQrCode" Width="150" Height="150" Margin="0,0,0,15" Visibility="Collapsed" HorizontalAlignment="Center"/>

                    <Button Content="Submit Charge" Height="45" Background="#10B981" Foreground="White" FontSize="16" FontWeight="SemiBold" Click="BtnSubmit_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="TxtStatus" Foreground="#EF4444" Margin="0,10,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
