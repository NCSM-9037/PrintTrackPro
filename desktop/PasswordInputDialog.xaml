<Window x:Class="PrintTrackPro.Desktop.PasswordInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Authentication" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" Topmost="True">
    
    <Grid Margin="20">
        <Border Background="#F8FAFC" CornerRadius="12" Padding="25" Width="380">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="0"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Admin Authentication Required" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Please enter the password to allow free printing." FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20" TextAlignment="Center"/>
                
                <!-- Password Box -->
                <PasswordBox x:Name="TxtPassword" Height="40" FontSize="16" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,20"/>
                
                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Cancel" Height="40" Background="#E2E8F0" Foreground="#475569" FontSize="14" FontWeight="SemiBold" Click="BtnCancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    
                    <Button Grid.Column="2" Content="Confirm" Height="40" Background="#EF4444" Foreground="White" FontSize="14" FontWeight="SemiBold" Click="BtnConfirm_Click" IsDefault="True">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
